{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Process Content",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/cms/scripts/processContent.js",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      },
      "skipFiles": [
        "<node_internals>/**"
      ],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Debug Fetch Content", 
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/cms/scripts/fetchContent.js",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      },
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}