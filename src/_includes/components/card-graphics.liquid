
          <div class="card pointer"
            data-ctype="graphic"
          {{- if card.title }}data-slug='{{ card.title | slugify }}'{{- endif }}
          {{- if card.download }}data-download='{{ card.download }}'{{- endif }}
          {{- if card.demozoo }}data-demozoo='{{ card.demozoo }}'{{- endif }}
          {{- if card.credits }}data-credits='{{ card.credits | jsonify }}'{{- endif }}
          {{- if card.card_image }}data-image='{{ card.card_image }}'{{- endif }}
          {{- if card.description }}data-description='{{ card.description }}'{{- endif }}
          {{- if card.release_date }}data-release_date='{{ card.release_date }}'{{- endif }}
          >
            {%- if card.asset %}
            <div class="card-image">
              <figure class="image is-4by3">
                <img src="{{ card.card_image }}" alt="image of the {{ card.type }} graphic {{ card.title }}" width="800" height="600" loading="lazy">
              </figure>
            </div>
            {%- endif %}
            <div class="card-content aligned-vertically bounce-hover">
              <div>
                <p class="subtitle">{{ card.type }} / {{ card.platform }}</p>
                <p class="title">{{ card.title }}</p>
              </div>
            </div>
          </div>